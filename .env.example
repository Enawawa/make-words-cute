# ============================================================
# Make Words Cute - Environment Variables
# ============================================================

# --- NextAuth ---
AUTH_SECRET=          # Run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# --- Database (Prisma + SQLite) ---
DATABASE_URL="file:./prisma/dev.db"

# --- WeChat Pay (微信支付) ---
# Leave blank for test mode (auto-confirms after 3s)
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=

# --- Email (SMTP) ---
# Leave blank for dev mode (OTP logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Make Words Cute <noreply@suno-fashion.com>"

# --- SiliconFlow AI ---
# Get at: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=
