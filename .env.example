# ============================================================
# Make Words Cute - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values

# --- NextAuth ---
AUTH_SECRET=          # Run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (Prisma) ---
DATABASE_URL="file:./prisma/dev.db"

# --- Stripe ---
# Dashboard: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=     # Create a $4.99/mo recurring price in Stripe

# --- Email (SMTP) ---
# Leave blank for dev mode (OTP logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Make Words Cute <noreply@suno-fashion.com>"

# --- SiliconFlow AI ---
# Get at: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=
