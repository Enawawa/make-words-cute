# ============================================================
# Make Words Cute - Environment Variables
# ============================================================
# No database needed! Fully stateless, works on Vercel out of the box.

# --- NextAuth ---
AUTH_SECRET=          # Required! Run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# --- WeChat Pay (微信支付) ---
# Leave blank for test mode (auto-confirms)
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=

# --- Email (SMTP) ---
# Leave blank for dev mode (OTP logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Make Words Cute <noreply@suno-fashion.com>"

# --- SiliconFlow AI ---
# Get at: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=
